# Copier ce fichier vers .env et ajuster les valeurs.

# Base de données (identifiants du docker-compose.yml / PostgreSQL local)
DATABASE_URL=postgresql://gkmarket:gkmarket_dev@localhost:5432/gkmarket

# --- Firebase ---
# Développement local : laisser les valeurs demo-* et lancer `npm run emulators`.
# Production : renseigner les vraies clés du projet Firebase et supprimer
# les variables *_EMULATOR_HOST ; définir FIREBASE_SERVICE_ACCOUNT (JSON du
# compte de service) pour firebase-admin.
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-gkmarket.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-gkmarket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-gkmarket.appspot.com
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
FIREBASE_PROJECT_ID=demo-gkmarket
FIREBASE_STORAGE_BUCKET=demo-gkmarket.appspot.com
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
