# Copier vers .env sur le VPS (non commité) et renseigner les valeurs réelles.
# Utilisé par docker-compose.prod.yml.

# --- PostgreSQL (généré au déploiement) ---
POSTGRES_PASSWORD=change-me-strong

# --- Firebase (projet deallome-staging) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=deallome-staging.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=deallome-staging
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=deallome-staging.firebasestorage.app
FIREBASE_PROJECT_ID=deallome-staging
FIREBASE_STORAGE_BUCKET=deallome-staging.firebasestorage.app
# JSON du compte de service sur UNE seule ligne (minifié)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# --- Déblocage automatique des paiements sécurisés (cron) ---
CRON_SECRET=change-me

# --- Emails (Brevo) — laissé vide = emails simulés/journalisés ---
# Clé API v3 (format xkeysib-...). ⚠ Si le compte Brevo a « Authorised IPs »
# activé, autoriser l'IP publique du VPS sinon tout envoi renvoie 401.
BREVO_API_KEY=
EMAIL_FROM=no-reply@deallome.com

# --- Mode démonstration : paiements Mobile Money simulés ---
DEMO_MODE=1
