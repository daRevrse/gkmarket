rules_version = '2';

// Documents KYC : chaque utilisateur ne peut écrire que dans son dossier.
// Aucune lecture côté client — la consultation passe par le serveur
// (firebase-admin contourne ces règles), réservée aux admins.
service firebase.storage {
  match /b/{bucket}/o {
    match /kyc/{userId}/{fileName} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024;
      allow read: if false;
    }

    // Photos produit : publiques en lecture (catalogue), écriture par le
    // vendeur dans son propre dossier, images uniquement.
    match /products/{userId}/{fileName} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read: if true;
    }
  }
}
